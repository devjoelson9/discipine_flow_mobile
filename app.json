{
  "expo": {
    "name": "discipline-flow-mobile",
    "slug": "discipline-flow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "edgeToEdgeEnabled": true
    },

    "web": {
      "bundler": "metro"
    },

    "plugins": ["expo-router"],

    "experiments": {
      "typedRoutes": true
    }
  }
}